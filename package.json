  "description": "Express.js + PostgreSQL backend for DalaliMkononi - Tanzania Real Estate & Rental Management Platform",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
